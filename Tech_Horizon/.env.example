# Backend Environment Variables Configuration
# Copy this file to .env and fill in your actual values for production

# ============================================
# DATABASE CONFIGURATION
# ============================================
# PostgreSQL connection string
# Format: jdbc:postgresql://HOST:PORT/DATABASE_NAME
DB_URL=jdbc:postgresql://localhost:5432/Tech_Horizon

# Database username (usually 'postgres' or your custom user)
DB_USERNAME=postgres

# Database password - MUST be strong in production!
# Use a secure random password, at least 16 characters
DB_PASSWORD=your_secure_password_here

# ============================================
# JWT (JSON Web Token) CONFIGURATION
# ============================================
# Secret key for JWT signing - MUST be at least 32 characters
# Generate with: openssl rand -base64 32
# NEVER use the default in production!
JWT_SECRET=your_super_secret_jwt_key_at_least_32_chars_long

# JWT expiration time in milliseconds (default: 1 hour = 3600000)
JWT_EXPIRATION=3600000

# ============================================
# EMAIL CONFIGURATION (Gmail)
# ============================================
# SMTP server host
MAIL_HOST=smtp.gmail.com

# SMTP server port (587 for TLS, 465 for SSL)
MAIL_PORT=587

# Gmail address for sending emails
MAIL_USERNAME=your_email@gmail.com

# Gmail App Password (NOT regular password!)
# Generate here: https://myaccount.google.com/apppasswords
# Instructions:
# 1. Enable 2-Factor Authentication on Gmail
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Select "Mail" and "Windows Computer"
# 4. Generate 16-character password
# 5. Copy that password here
MAIL_PASSWORD=your_gmail_app_password_here

# ============================================
# SERVER CONFIGURATION
# ============================================
# Server port
SERVER_PORT=8080

# ============================================
# JPA/HIBERNATE CONFIGURATION
# ============================================
# DDL Auto mode
# - LOCAL/DEV: create-drop (recreates schema on each startup)
# - PRODUCTION: validate (checks schema without modifying)
JPA_DDL_AUTO=validate

# Show SQL queries in logs
# - LOCAL/DEV: true (for debugging)
# - PRODUCTION: false (performance optimization)
SHOW_SQL=false

# ============================================
# ENVIRONMENT PROFILE
# ============================================
# Spring profile to activate
# Options: development, production
SPRING_PROFILES_ACTIVE=production
